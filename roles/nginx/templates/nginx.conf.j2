events {}

http {
	include /etc/nginx/conf.d/*.conf;	
    server {
        listen {{ nginx_port | default(80) }};
        server_name {{ nginx_domain | default('localhost') }};
        access_log /var/log/nginx/access.log;
        error_log  /var/log/nginx/error.log;

        location / {
            root /var/www/html;
            index index.html index.htm;
        }
    }
}
